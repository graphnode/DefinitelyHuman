@page "/"
@rendermode InteractiveServer

@using System.Globalization
@using DefinitelyHuman.Agent
@using DefinitelyHuman.Data
@using DefinitelyHuman.Irc
@using DefinitelyHuman.Web.Components.Chat
@using Microsoft.AspNetCore.Components.Web.Virtualization
@using Microsoft.Data.Sqlite
@using LinkPreviewService = DefinitelyHuman.Utilities.LinkPreviewService

@inject IrcBot Bot
@inject AgentLog AgentLog
@inject LinkPreviewService Previews

@implements IDisposable

<div class="page-header">
    <h2>Timeline</h2>
</div>

<div class="page-body">
    <ChatVirtualize @ref="_virtualizer" TItem="TimelineRow" ItemsProvider="ProvideRows" ItemSize="28">
        <ItemContent>
            @if (context.ShowDaySeparator)
            {
                <div class="tl-day-sep">
                    <hr /><span>@FormatDate(context.Timestamp)</span><hr />
                </div>
            }
            @if (context.IsMessage)
            {
                <div class="tl-row tl-msg @MsgRowClass(context)">
                    <span class="tl-time">@context.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    <span class="tl-nick" style="color:@NickColor(context.Nick!, context.IsOwnMessage)">@context.Nick</span>
                    <div class="tl-content">
                        <span class="tl-text">@RenderText(context.Text!)</span>
                        @foreach (var preview in GetPreviews(context.Text!))
                        {
                            @if (preview.IsImageOnly)
                            {
                                <a class="tl-thumb" href="@preview.Url" target="_blank" rel="noopener">
                                    <img src="@preview.ImageUrl" alt="" loading="lazy"
                                         onerror="this.parentElement.style.display='none'" />
                                </a>
                            }
                            else
                            {
                                <a class="tl-preview" href="@preview.Url" target="_blank" rel="noopener">
                                    @if (preview.ImageUrl is not null)
                                    {
                                        <img class="tl-preview-img" src="@preview.ImageUrl" alt="" loading="lazy"
                                             onerror="this.style.display='none'" />
                                    }
                                    <div class="tl-preview-body">
                                        @if (preview.Title is not null)
                                        {
                                            <div class="tl-preview-title">@preview.Title</div>
                                        }
                                        @if (preview.Description is not null)
                                        {
                                            <div class="tl-preview-desc">@Truncate(preview.Description, 160)</div>
                                        }
                                        <div class="tl-preview-site">@Domain(preview.Url)</div>
                                    </div>
                                </a>
                            }
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="tl-row tl-evt @($"k-{context.Kind!.ToString()!.ToLowerInvariant()}")">
                    <span class="tl-time">@context.Timestamp.ToLocalTime().ToString("HH:mm:ss")</span>
                    <span class="tl-marker">~</span>
                    @if (!string.IsNullOrEmpty(context.Detail))
                    {
                        <details class="tl-detail">
                            <summary>@context.Summary</summary>
                            <pre>@context.Detail</pre>
                        </details>
                    }
                    else
                    {
                        <span class="tl-summary">@context.Summary</span>
                    }
                </div>
            }
        </ItemContent>
    </ChatVirtualize>
</div>

@code {
    private sealed record TimelineRow(
        DateTime Timestamp,
        bool IsMessage,
        bool ShowDaySeparator = false,
        string? Nick = null,
        string? Text = null,
        bool IsOwnMessage = false,
        AgentEventKind? Kind = null,
        string? Summary = null,
        string? Detail = null);

    private ChatVirtualize<TimelineRow>? _virtualizer;

    protected override void OnInitialized()
    {
        Bot.MessageLogged += OnMessageLogged;
        AgentLog.Updated += OnAgentUpdated;
        Previews.PreviewReady += OnPreviewReady;
    }

    private Task OnMessageLogged() { OnChanged(); return Task.CompletedTask; }
    private void OnAgentUpdated() => OnChanged();
    private void OnPreviewReady() => _ = InvokeAsync(StateHasChanged);

    private void OnChanged() => _ = InvokeAsync(async () =>
    {
        if (_virtualizer is not null)
            await _virtualizer.RefreshDataAsync();
    });

    // ------------------------------------------------------------------ ItemsProvider

    private static string DbPath => Path.Join(
        Environment.GetFolderPath(Environment.SpecialFolder.LocalApplicationData), "chatting.db");

    private async ValueTask<ItemsProviderResult<TimelineRow>> ProvideRows(ItemsProviderRequest request)
    {
        await using var conn = new SqliteConnection($"Data Source={DbPath}");
        await conn.OpenAsync(request.CancellationToken);

        int totalCount = Convert.ToInt32(
            await Exec(conn, "SELECT (SELECT COUNT(*) FROM Messages) + (SELECT COUNT(*) FROM AgentEvents)"));

        if (totalCount == 0 || request.Count == 0)
            return new ItemsProviderResult<TimelineRow>([], totalCount);

        // Previous item's timestamp for day-separator detection at page boundary.
        DateTime? prevTimestamp = null;
        if (request.StartIndex > 0)
        {
            var ts = await Exec(conn, """
                SELECT Timestamp FROM (
                    SELECT Timestamp FROM Messages UNION ALL SELECT Timestamp FROM AgentEvents
                ) ORDER BY Timestamp LIMIT 1 OFFSET @o
                """, ("@o", request.StartIndex - 1));
            if (ts is string s) prevTimestamp = DateTime.Parse(s, null, DateTimeStyles.RoundtripKind);
        }

        await using var cmd = conn.CreateCommand();
        cmd.CommandText = """
            SELECT Timestamp, IsMessage, Nick, Text, IsOwnMessage, Kind, Summary, Detail FROM (
                SELECT Timestamp, 1 AS IsMessage, Nick, Text, IsOwnMessage,
                       NULL AS Kind, NULL AS Summary, NULL AS Detail FROM Messages
                UNION ALL
                SELECT Timestamp, 0, NULL, NULL, 0, Kind, Summary, Detail FROM AgentEvents
            ) ORDER BY Timestamp LIMIT @n OFFSET @o
            """;
        cmd.Parameters.AddWithValue("@n", request.Count);
        cmd.Parameters.AddWithValue("@o", request.StartIndex);

        var rows = new List<TimelineRow>();
        DateOnly? lastDate = prevTimestamp.HasValue
            ? DateOnly.FromDateTime(prevTimestamp.Value.ToLocalTime())
            : null;

        await using var reader = await cmd.ExecuteReaderAsync(request.CancellationToken);
        while (await reader.ReadAsync(request.CancellationToken))
        {
            var timestamp = DateTime.Parse(reader.GetString(0), null, DateTimeStyles.RoundtripKind);
            bool isMessage = reader.GetInt32(1) == 1;

            TimelineRow row;
            if (isMessage)
            {
                row = new TimelineRow(timestamp, true,
                    Nick: reader.GetString(2),
                    Text: reader.GetString(3),
                    IsOwnMessage: reader.GetInt32(4) != 0);
            }
            else
            {
                row = new TimelineRow(timestamp, false,
                    Kind: Enum.Parse<AgentEventKind>(reader.GetString(5)),
                    Summary: reader.GetString(6),
                    Detail: reader.IsDBNull(7) ? null : reader.GetString(7));
            }

            var localDate = DateOnly.FromDateTime(row.Timestamp.ToLocalTime());
            if (lastDate is null || localDate != lastDate)
            {
                row = row with { ShowDaySeparator = true };
                lastDate = localDate;
            }
            rows.Add(row);
        }

        return new ItemsProviderResult<TimelineRow>(rows, totalCount);
    }

    private static async Task<object?> Exec(SqliteConnection conn, string sql, params (string name, object value)[] args)
    {
        await using var cmd = conn.CreateCommand();
        cmd.CommandText = sql;
        foreach (var (name, value) in args)
            cmd.Parameters.AddWithValue(name, value);
        return await cmd.ExecuteScalarAsync();
    }

    // --- Nick colors (deterministic hue from nick hash, a la Halloy) ---

    private static uint Fnv1a(string s)
    {
        uint hash = 2166136261;
        foreach (char c in s)
        {
            hash ^= c;
            hash *= 16777619;
        }
        return hash;
    }

    private static string NickColor(string nick, bool isOwn)
    {
        if (isOwn) return "var(--own-msg)";
        int hue = (int)(Fnv1a(nick) % 360);
        return $"hsl({hue}, 70%, 68%)";
    }

    // --- Message rendering ---

    private string MsgRowClass(TimelineRow row)
    {
        if (row.IsOwnMessage) return "own-message";
        return MentionsBot(row.Text!) ? "mention" : "";
    }

    private bool MentionsBot(string text) =>
        !string.IsNullOrEmpty(Bot.Nick) && text.Contains(Bot.Nick, StringComparison.OrdinalIgnoreCase);

    private MarkupString RenderText(string text)
    {
        var sb = new System.Text.StringBuilder();
        int lastIdx = 0;

        foreach (System.Text.RegularExpressions.Match m in LinkPreviewService.ExtractUrls(text))
        {
            var url = LinkPreviewService.CleanUrl(m.Value);
            if (url.Length == 0) continue;

            sb.Append(System.Net.WebUtility.HtmlEncode(text[lastIdx..m.Index]));

            var hrefEncoded = System.Net.WebUtility.HtmlEncode(url);
            sb.Append($"<a href=\"{hrefEncoded}\" class=\"tl-link\" target=\"_blank\" rel=\"noopener\">{hrefEncoded}</a>");

            lastIdx = m.Index + url.Length;
        }

        sb.Append(System.Net.WebUtility.HtmlEncode(text[lastIdx..]));

        var result = sb.ToString();

        if (!string.IsNullOrEmpty(Bot.Nick))
        {
            var pattern = System.Text.RegularExpressions.Regex.Escape(System.Net.WebUtility.HtmlEncode(Bot.Nick));
            result = System.Text.RegularExpressions.Regex.Replace(
                result, pattern,
                match => $"<span class=\"hl-nick\">{match.Value}</span>",
                System.Text.RegularExpressions.RegexOptions.IgnoreCase);
        }

        return (MarkupString)result;
    }

    // --- Link previews ---

    private IEnumerable<LinkPreviewService.LinkPreview> GetPreviews(string text)
    {
        foreach (System.Text.RegularExpressions.Match m in LinkPreviewService.ExtractUrls(text))
        {
            var url = LinkPreviewService.CleanUrl(m.Value);
            if (url.Length == 0) continue;
            var preview = Previews.GetPreview(url);
            if (preview is not null)
                yield return preview;
        }
    }

    private static string Domain(string url) =>
        Uri.TryCreate(url, UriKind.Absolute, out var uri) ? uri.Host : url;

    private static string Truncate(string s, int max) =>
        s.Length <= max ? s : s[..(max - 1)] + "…";

    private static string FormatDate(DateTime utcTimestamp) =>
        utcTimestamp.ToLocalTime().ToString("dddd, d MMMM yyyy", CultureInfo.InvariantCulture);

    public void Dispose()
    {
        Bot.MessageLogged -= OnMessageLogged;
        AgentLog.Updated -= OnAgentUpdated;
        Previews.PreviewReady -= OnPreviewReady;
    }
}
