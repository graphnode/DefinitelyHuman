@page "/reasoning"
@rendermode InteractiveServer
@using DefinitelyHuman.Agent
@inject AgentLog Log
@implements IDisposable

<div class="page-header">
    <h2>Decision Log</h2>
</div>

<div class="page-body">
    @if (_entries.Count == 0)
    {
        <div class="empty-state">No decisions yet.</div>
    }
    else
    {
        <table class="message-log">
            <thead>
                <tr>
                    <th>Time</th>
                    <th>Kind</th>
                    <th>Detail</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var e in _entries)
                {
                    <tr class="@($"k-{e.Kind.ToString().ToLowerInvariant()}")">
                        <td class="col-time">@e.At.ToLocalTime().ToString("HH:mm:ss")</td>
                        <td class="col-kind">@e.Kind</td>
                        <td class="col-text">@e.Text</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    // Newest first, so there's no scroll-to-bottom to manage.
    private IReadOnlyList<AgentLog.Entry> _entries = Array.Empty<AgentLog.Entry>();

    protected override void OnInitialized()
    {
        Refresh();
        Log.Updated += OnUpdated;
    }

    private void OnUpdated() => _ = InvokeAsync(() => { Refresh(); StateHasChanged(); });

    private void Refresh()
    {
        var arr = Log.Recent().ToArray();
        Array.Reverse(arr);
        _entries = arr;
    }

    public void Dispose() => Log.Updated -= OnUpdated;
}
