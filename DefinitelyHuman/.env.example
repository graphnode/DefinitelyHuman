# Copy this file to ".env" (same folder) and fill in your real values.
# ".env" is gitignored so your secrets never get committed.

# Anthropic API key used by the chat agent.
# Create one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-your-key-here

# IRC connection settings (these defaults match a local test server).
IRC_HOST=localhost
IRC_PORT=6667
IRC_PASSWORD=
IRC_CHANNEL="#clankersunite"
IRC_NICK=DefinitelyHuman
